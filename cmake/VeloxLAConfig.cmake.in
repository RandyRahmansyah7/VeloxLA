@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(@VELOXLA_ENABLE_OPENMP@)
    find_dependency(OpenMP)
endif()

if(@VELOXLA_USE_OPENBLAS@)
    find_dependency(OpenBLAS)
endif()

if(@VELOXLA_USE_MKL@)
    find_dependency(MKL)
endif()

if(@VELOXLA_USE_BLIS@)
    find_dependency(BLIS)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/VeloxLATargets.cmake")

check_required_components(VeloxLA)
